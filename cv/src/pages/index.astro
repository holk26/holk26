---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Summary from '../components/Summary.astro';
import Skills from '../components/Skills.astro';
import Experience from '../components/Experience.astro';
import Education from '../components/Education.astro';
import Certifications from '../components/Certifications.astro';
import Languages from '../components/Languages.astro';

import cv from '../../cv.json';
---

<Layout title={`${cv.personal.name} – CV`}>
  <main class="cv-page">
    <aside class="cv-sidebar">
      <Header personal={cv.personal} />
      <Skills skills={cv.skills} />
      <Languages languages={cv.languages} />
    </aside>
    <div class="cv-main">
      <Summary summary={cv.summary} />
      <Experience experience={cv.experience} />
      <Education education={cv.education} />
      <Certifications certifications={cv.certifications} />
    </div>
  </main>

  <!-- Print button – hidden when printing -->
  <div class="print-btn-wrapper no-print">
    <button onclick="window.print()" class="print-btn" aria-label="Print or save CV as PDF">🖨&nbsp; Save as PDF</button>
  </div>
</Layout>

<style>
  .print-btn-wrapper {
    display: flex;
    justify-content: center;
    margin: 20px 0 40px;
  }

  .print-btn {
    background: var(--sidebar-bg);
    color: #fff;
    border: none;
    padding: 11px 32px;
    font-size: 10pt;
    font-family: var(--font-main);
    font-weight: 600;
    border-radius: 8px;
    cursor: pointer;
    letter-spacing: 0.05em;
    box-shadow: 0 4px 14px rgba(13, 27, 42, 0.4);
    transition: background 0.2s, transform 0.1s;
  }

  .print-btn:hover {
    background: var(--color-primary);
    transform: translateY(-1px);
  }

  @media print {
    .no-print {
      display: none !important;
    }
  }
</style>
