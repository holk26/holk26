---
interface LanguageItem {
  language: string;
  level: string;
}

interface Props {
  languages: LanguageItem[];
}
const { languages } = Astro.props;
---

<section>
  <h2>Language Proficiency</h2>
  <div class="lang-grid">
    {
      languages.map((lang) => (
        <div class="lang-card">
          <span class="lang-name">{lang.language}</span>
          <span class="lang-level">{lang.level}</span>
        </div>
      ))
    }
  </div>
</section>

<style>
  .lang-grid {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
  }

  .lang-card {
    display: flex;
    flex-direction: column;
    gap: 2px;
    background: var(--color-bg-subtle);
    border: 1px solid var(--color-border);
    border-radius: 6px;
    padding: 6px 14px;
    min-width: 140px;
  }

  .lang-name {
    font-size: 9.5pt;
    font-weight: 700;
    color: var(--color-primary);
  }

  .lang-level {
    font-size: 8.5pt;
    color: var(--color-text-muted);
  }
</style>
