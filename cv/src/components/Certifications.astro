---
interface Props {
  certifications: string[];
}
const { certifications } = Astro.props;
---

<section>
  <h2>Certifications</h2>
  <ul class="cert-list">
    {
      certifications.map((cert) => (
        <li class="cert-chip">{cert}</li>
      ))
    }
  </ul>
</section>

<style>
  .cert-list {
    display: flex;
    flex-wrap: wrap;
    gap: 6px;
  }

  .cert-chip {
    display: inline-flex;
    align-items: center;
    font-size: 8.5pt;
    font-weight: 500;
    color: var(--color-primary);
    background: var(--color-bg-subtle);
    border: 1px solid var(--color-border);
    border-radius: 5px;
    padding: 3px 10px;
    line-height: 1.5;
  }
</style>
