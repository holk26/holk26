---
interface Props {
  personal: {
    name: string;
    location: string;
    phone: string;
    email: string;
    linkedin: string;
    github: string;
    workAuthorization: string;
  };
}
const { personal } = Astro.props;
---

<header class="cv-header">
  <div class="header-inner">
    <div class="header-top">
      <h1>{personal.name}</h1>
      <span class="permit-badge">{personal.workAuthorization}</span>
    </div>
    <div class="contact-bar">
      <a href={`mailto:${personal.email}`} class="contact-item">
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true">
          <path d="M3 4a2 2 0 0 0-2 2v.5l9 5.25L19 6.5V6a2 2 0 0 0-2-2H3Z"/>
          <path d="M19 8.75l-8.572 5l-.928.54-.928-.54L1 8.75V14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V8.75Z"/>
        </svg>
        {personal.email}
      </a>
      <span class="dot" aria-hidden="true"></span>
      <a href={`tel:${personal.phone.replace(/\s/g, '')}`} class="contact-item">
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true">
          <path fill-rule="evenodd" d="M2 3.5A1.5 1.5 0 0 1 3.5 2h1.148a1.5 1.5 0 0 1 1.465 1.175l.716 3.223a1.5 1.5 0 0 1-1.052 1.767l-.933.267c-.41.117-.643.555-.48.95a11.542 11.542 0 0 0 6.254 6.254c.395.163.833-.07.95-.48l.267-.933a1.5 1.5 0 0 1 1.767-1.052l3.223.716A1.5 1.5 0 0 1 18 16.352V17.5a1.5 1.5 0 0 1-1.5 1.5H15c-1.149 0-2.263-.15-3.326-.43A13.022 13.022 0 0 1 2.43 8.326 13.019 13.019 0 0 1 2 5V3.5Z" clip-rule="evenodd"/>
        </svg>
        {personal.phone}
      </a>
      <span class="dot" aria-hidden="true"></span>
      <span class="contact-item">
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true">
          <path fill-rule="evenodd" d="M9.69 18.933l.003.001C9.89 19.02 10 19 10 19s.11.02.308-.066l.002-.001.006-.003.018-.008a5.741 5.741 0 0 0 .281-.14c.186-.096.446-.24.757-.433.62-.384 1.445-.966 2.274-1.765C15.302 15.526 17 13.143 17 10a7 7 0 1 0-14 0c0 3.143 1.698 5.526 3.354 7.105.83.799 1.654 1.38 2.274 1.765.31.194.57.337.757.433a5.74 5.74 0 0 0 .282.14l.018.008.006.003ZM10 11.25a1.25 1.25 0 1 0 0-2.5 1.25 1.25 0 0 0 0 2.5Z" clip-rule="evenodd"/>
        </svg>
        {personal.location}
      </span>
      <span class="dot" aria-hidden="true"></span>
      <a href={personal.linkedin} target="_blank" rel="noopener" class="contact-item">
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
          <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 0 1-2.063-2.065 2.064 2.064 0 1 1 2.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
        </svg>
        LinkedIn
      </a>
      <span class="dot" aria-hidden="true"></span>
      <a href={personal.github} target="_blank" rel="noopener" class="contact-item">
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
          <path d="M12 .297c-6.63 0-12 5.373-12 12 0 5.303 3.438 9.8 8.205 11.385.6.113.82-.258.82-.577 0-.285-.01-1.04-.015-2.04-3.338.724-4.042-1.61-4.042-1.61C4.422 18.07 3.633 17.7 3.633 17.7c-1.087-.744.084-.729.084-.729 1.205.084 1.838 1.236 1.838 1.236 1.07 1.835 2.809 1.305 3.495.998.108-.776.417-1.305.76-1.605-2.665-.3-5.466-1.332-5.466-5.93 0-1.31.465-2.38 1.235-3.22-.135-.303-.54-1.523.105-3.176 0 0 1.005-.322 3.3 1.23.96-.267 1.98-.399 3-.405 1.02.006 2.04.138 3 .405 2.28-1.552 3.285-1.23 3.285-1.23.645 1.653.24 2.873.12 3.176.765.84 1.23 1.91 1.23 3.22 0 4.61-2.805 5.625-5.475 5.92.42.36.81 1.096.81 2.22 0 1.606-.015 2.896-.015 3.286 0 .315.21.69.825.57C20.565 22.092 24 17.592 24 12.297c0-6.627-5.373-12-12-12"/>
        </svg>
        GitHub
      </a>
    </div>
  </div>
</header>

<style>
  .cv-header {
    background: linear-gradient(135deg, #1e3a5f 0%, #2563eb 100%);
    padding: 28px 22mm 22px;
  }

  .header-top {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    gap: 12px;
    flex-wrap: wrap;
    margin-bottom: 14px;
  }

  .permit-badge {
    display: inline-flex;
    align-items: center;
    margin-top: 6px;
    font-size: 8pt;
    font-weight: 600;
    letter-spacing: 0.07em;
    text-transform: uppercase;
    color: #1e3a5f;
    background: #bfdbfe;
    padding: 3px 10px;
    border-radius: 20px;
    white-space: nowrap;
    flex-shrink: 0;
  }

  .contact-bar {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 4px 0;
    font-size: 8.5pt;
  }

  .contact-item {
    display: inline-flex;
    align-items: center;
    gap: 5px;
    color: #bfdbfe;
    text-decoration: none;
    transition: color 0.15s;
  }

  .contact-item:hover {
    color: var(--color-bg);
    text-decoration: none;
  }

  .contact-item svg {
    width: 13px;
    height: 13px;
    flex-shrink: 0;
    opacity: 0.85;
  }

  .dot {
    display: inline-block;
    width: 3px;
    height: 3px;
    border-radius: 50%;
    background: rgba(191, 219, 254, 0.5);
    margin: 0 10px;
    flex-shrink: 0;
  }

  @media print {
    .cv-header {
      padding: 18px 14mm 14px;
      background: linear-gradient(135deg, #1e3a5f 0%, #2563eb 100%) !important;
      -webkit-print-color-adjust: exact;
      print-color-adjust: exact;
    }

    h1 { font-size: 20pt; }
    .contact-bar { font-size: 8pt; }
    .permit-badge { font-size: 7.5pt; }
  }
</style>
