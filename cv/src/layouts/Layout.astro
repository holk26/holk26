---
interface Props {
  title: string;
}
const { title } = Astro.props;
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content="Professional CV – Homero Cabrera Araque" />
    <title>{title}</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link
      rel="preconnect"
      href="https://fonts.gstatic.com"
      crossorigin="anonymous"
    />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap"
      rel="stylesheet"
    />
  </head>
  <body>
    <slot />
  </body>
</html>

<style is:global>
  /* ── Reset & Base ── */
  *,
  *::before,
  *::after {
    box-sizing: border-box;
    margin: 0;
    padding: 0;
  }

  :root {
    /* Main content */
    --color-primary: #1e3a5f;
    --color-primary-light: #2563eb;
    --color-accent: #3b82f6;
    --color-text: #0f172a;
    --color-text-muted: #475569;
    --color-border: #e2e8f0;
    --color-bg: #ffffff;
    --color-bg-subtle: #f0f7ff;
    --color-tag-bg: #dbeafe;
    --color-tag-text: #1e40af;
    /* Sidebar */
    --sidebar-bg: #0d1b2a;
    --sidebar-text: #f1f5f9;
    --sidebar-muted: #8b9cb5;
    --sidebar-accent: #60a5fa;
    --sidebar-border: rgba(255, 255, 255, 0.08);
    --font-main: 'Inter', 'Segoe UI', Arial, sans-serif;
    /* backward-compat alias — intentionally mirrors --color-primary-light */
    --color-accent-light: var(--color-primary-light);
  }

  html,
  body {
    background: #e8eef6;
    font-family: var(--font-main);
    font-size: 11pt;
    color: var(--color-text);
    line-height: 1.5;
  }

  /* ── Page wrapper — two-column grid ── */
  .cv-page {
    max-width: 210mm;
    min-height: 297mm;
    margin: 28px auto;
    box-shadow: 0 8px 40px rgba(15, 23, 42, 0.15);
    border-radius: 4px;
    overflow: hidden;
    display: grid;
    grid-template-columns: 33% 67%;
  }

  /* ── Sidebar column ── */
  .cv-sidebar {
    background: var(--sidebar-bg);
    -webkit-print-color-adjust: exact;
    print-color-adjust: exact;
  }

  /* ── Main content column ── */
  .cv-main {
    background: var(--color-bg);
    padding: 28px 26px;
  }

  /* ── Typography ── */
  h1 {
    font-size: 18pt;
    font-weight: 700;
    color: var(--color-text);
    line-height: 1.2;
  }

  h2 {
    font-size: 8.5pt;
    font-weight: 700;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--color-primary);
    margin-bottom: 8px;
    padding-left: 10px;
    border-left: 3px solid var(--color-accent);
    border-bottom: none;
  }

  h3 {
    font-size: 10.5pt;
    font-weight: 600;
    color: var(--color-text);
    margin-bottom: 1px;
  }

  p, li {
    font-size: 9.5pt;
    color: var(--color-text-muted);
    line-height: 1.55;
  }

  ul {
    list-style: none;
    padding: 0;
  }

  a {
    color: var(--color-primary-light);
    text-decoration: none;
  }

  a:hover {
    text-decoration: underline;
  }

  /* ── Section spacing ── */
  section {
    margin-bottom: 18px;
  }

  /* ── Print / PDF ── */
  @media print {
    html,
    body {
      background: #fff;
      font-size: 10pt;
    }

    .cv-page {
      margin: 0;
      box-shadow: none;
      border-radius: 0;
      max-width: 100%;
      min-height: auto;
    }

    .cv-sidebar {
      -webkit-print-color-adjust: exact;
      print-color-adjust: exact;
    }

    .cv-main {
      padding: 18px 20px;
    }

    h2 { font-size: 8pt; }
    h3 { font-size: 9.5pt; }
    p, li { font-size: 9pt; }

    section {
      margin-bottom: 10px;
      page-break-inside: avoid;
    }

    a {
      color: var(--color-primary-light);
      text-decoration: none;
    }
  }

  @page {
    size: letter;
    margin: 0;
  }
</style>
